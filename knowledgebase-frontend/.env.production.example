# 生产环境配置（复制为 .env.production，build 时自动生效）
# 与 after-sales-ai 一致：.NET 在 6713，Python 在 4013；同域部署时可用相对路径
#
# 方式一：显式指定（推荐，与 after-sales-ai 一致）
VITE_API_BASE=https://www.yonghongjituan.com:6713
VITE_PYTHON_BASE=https://www.yonghongjituan.com:4013
#
# 方式二：同域部署（前端在 4013/learning/，API 也在 4013）时可不填，默认用相对路径 /api、/python-api
# VITE_API_BASE=
# VITE_PYTHON_BASE=
#
VITE_INTERNAL_TOKEN=your-internal-token
VITE_DEFAULT_TENANT=default
